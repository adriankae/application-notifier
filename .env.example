# Backend config: these can be omitted if czm already has a config.toml on disk.
# If present, explicit env vars win over the czm config file.
CZM_BASE_URL=http://localhost:28173
CZM_API_KEY=
CZM_TIMEZONE=Europe/Berlin
CZM_CONFIG_PATH=

# OpenClaw handoff.
# OPENCLAW_BRIDGE_COMMAND should be the existing OpenClaw-side command/script that
# consumes the structured reminder payload and instructions, then asks OpenClaw to
# compose the final reminder and send it through the already configured bot/chat loop.
OPENCLAW_BRIDGE_MODE=command
OPENCLAW_BRIDGE_COMMAND=/app/application-notifier/deploy/openclaw-reminder-wrapper.sh
OPENCLAW_BRIDGE_FALLBACK_COMMAND=
OPENCLAW_BRIDGE_TARGET=
OPENCLAW_BRIDGE_TIMEOUT_SECONDS=120
OPENCLAW_PYTHON_BIN=python3
OPENCLAW_REMINDER_COMPOSE_COMMAND=
OPENCLAW_REMINDER_STYLE_GUIDE=
OPENCLAW_REMINDER_STYLE_FILE=/app/application-notifier/deploy/openclaw-reminder-style-guide.txt

# Runtime deployment assumptions.
OPENCLAW_CONTAINER_NAME=
NOTIFIER_DEPLOY_PATH_IN_CONTAINER=/app/application-notifier
APPLICATION_NOTIFIER_LOCK_PATH=/tmp/application-notifier.lock
